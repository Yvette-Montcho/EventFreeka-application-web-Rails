<%# app/views/devise/shared/_links.html.erb — Partial partagée entre les vues Devise %>
<%# Affiche les liens contextuels selon la page affichée et le statut de connexion %>
<%# Rails sait automatiquement quels liens afficher grâce aux helpers Devise %>

<nav class="mt-2">

  <%# Lien "Mot de passe oublié ?" — visible sur la page de connexion %>
  <%# devise_mapping.recoverable? => vérifie que le module Recoverable est activé %>
  <% if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
    <%= link_to "Mot de passe oublié ?", new_password_path(resource_name),
        class: "d-block text-muted small mb-1" %>
  <% end %>

  <%# Lien "Créer un compte" — visible sur la page de connexion %>
  <%# devise_mapping.registerable? => vérifie que le module Registerable est activé %>
  <% if devise_mapping.registerable? && controller_name != 'registrations' %>
    <%= link_to "Pas encore de compte ? S'inscrire", new_registration_path(resource_name),
        class: "d-block text-muted small mb-1" %>
  <% end %>

  <%# Lien "Se connecter" — visible sur les pages d'inscription et de mot de passe oublié %>
  <% if controller_name != 'sessions' %>
    <%= link_to "Déjà un compte ? Se connecter", new_session_path(resource_name),
        class: "d-block text-muted small mb-1" %>
  <% end %>

  <%# Lien de renvoi des instructions de confirmation (si module Confirmable activé) %>
  <%# devise_mapping.confirmable? => vérifie que le module Confirmable est activé %>
  <% if devise_mapping.confirmable? && controller_name != 'confirmations' %>
    <%= link_to "Renvoyer les instructions de confirmation", new_confirmation_path(resource_name),
        class: "d-block text-muted small mb-1" %>
  <% end %>

</nav>
