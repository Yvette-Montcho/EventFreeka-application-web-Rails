<%# app/views/events/index.html.erb — Page d'accueil : liste de tous les événements à venir %>

<%# ===== SECTION HERO (JUMBOTRON) ===== %>
<%# Section d'accroche en haut de la page d'accueil %>
<div class="p-5 mb-4 bg-dark text-white rounded-3 shadow">
  <div class="container-fluid py-3 text-center">
    <%# Titre principal de la page d'accueil %>
    <h1 class="display-4 fw-bold">🎉 Bienvenue sur EventFreeka</h1>

    <%# Sous-titre explicatif %>
    <p class="col-md-8 mx-auto fs-5 text-light">
      Découvrez, créez et participez aux événements qui animent votre ville.
      Des concerts aux ateliers créatifs, trouvez ce qui vous passionne !
    </p>

    <%# Bouton d'appel à l'action : créer un événement ou s'inscrire %>
    <% if user_signed_in? %>
      <%# Si connecté : lien vers la création d'événement %>
      <%= link_to "➕ Créer un événement", new_event_path,
          class: "btn btn-warning btn-lg fw-bold mt-2" %>
    <% else %>
      <%# Si non connecté : invitation à s'inscrire %>
      <%= link_to "🚀 Rejoindre EventFreeka", new_user_registration_path,
          class: "btn btn-warning btn-lg fw-bold mt-2" %>
    <% end %>
  </div>
</div>

<%# ===== LISTE DES ÉVÉNEMENTS ===== %>
<div class="row mb-3">
  <%# Titre de la section %>
  <div class="col">
    <h2 class="fw-bold">📅 Événements à venir</h2>
    <%# Sous-titre affichant le nombre d'événements trouvés %>
    <p class="text-muted"><%= @events.count %> événement(s) disponible(s)</p>
  </div>
</div>

<%# Vérifie s'il y a des événements à afficher %>
<% if @events.any? %>

  <%# Grille responsive : 1 colonne sur mobile, 2 sur tablette, 3 sur desktop %>
  <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">

    <%# Boucle sur chaque événement chargé depuis le controller %>
    <% @events.each do |event| %>
      <div class="col">

        <%# Carte Bootstrap pour chaque événement %>
        <div class="card h-100 shadow-sm border-0">

          <%# En-tête de la carte avec fond coloré et badge de prix %>
          <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <%# Titre de l'événement (tronqué si trop long) %>
            <span class="fw-bold text-truncate"><%= event.title %></span>

            <%# Badge affichant "Gratuit" ou le prix de l'événement %>
            <% if event.free? %>
              <span class="badge bg-success ms-2">Gratuit</span>
            <% else %>
              <%# number_to_currency formate le prix en euros avec le symbole € %>
              <span class="badge bg-warning text-dark ms-2">
                <%= number_to_currency(event.price, unit: "€", format: "%n %u") %>
              </span>
            <% end %>
          </div>

          <%# Corps de la carte avec les informations principales %>
          <div class="card-body">
            <%# Description tronquée à 120 caractères pour uniformiser les cartes %>
            <p class="card-text text-muted">
              <%= truncate(event.description, length: 120) %>
            </p>

            <%# Informations rapides sur l'événement avec des icônes %>
            <ul class="list-unstyled small">
              <%# Date et heure de début de l'événement %>
              <li>
                📅 <strong>Date :</strong>
                <%# strftime formate la date en français : "lundi 22 avril 2026 à 14h30" %>
                <%= event.start_date.strftime("%A %d %B %Y à %Hh%M") %>
              </li>

              <%# Durée de l'événement %>
              <li>
                ⏱ <strong>Durée :</strong> <%= event.duration %>h
              </li>

              <%# Lieu de l'événement %>
              <li>
                📍 <strong>Lieu :</strong> <%= event.location %>
              </li>

              <%# Organisateur de l'événement %>
              <li>
                👤 <strong>Par :</strong> <%= event.admin.full_name %>
              </li>

              <%# Nombre de participants inscrits %>
              <li>
                👥 <strong>Participants :</strong> <%= event.participants_count %>
              </li>
            </ul>
          </div>

          <%# Pied de la carte avec le lien vers la page détail de l'événement %>
          <div class="card-footer bg-transparent border-0">
            <%# link_to génère un lien <a> vers la page show de l'événement %>
            <%= link_to "Voir l'événement →", event_path(event),
                class: "btn btn-outline-primary btn-sm w-100" %>
          </div>

        </div>
      </div>
    <% end %>
  </div>

<% else %>
  <%# Message affiché quand aucun événement n'est disponible %>
  <div class="text-center py-5">
    <div class="display-1">🗓️</div>
    <h3 class="mt-3 text-muted">Aucun événement à venir pour le moment</h3>
    <p class="text-muted">Soyez le premier à créer un événement dans votre ville !</p>

    <%# Invite l'utilisateur à créer le premier événement %>
    <% if user_signed_in? %>
      <%= link_to "Créer le premier événement", new_event_path, class: "btn btn-primary mt-2" %>
    <% else %>
      <%= link_to "S'inscrire pour créer un événement", new_user_registration_path,
          class: "btn btn-primary mt-2" %>
    <% end %>
  </div>
<% end %>
